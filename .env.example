# Modèle d'environnement — COPIER vers .env et remplir (le .env réel n'est pas commité).
# cp .env.example .env

# Webhook Discord pour la remontée des erreurs serveur (laisser vide = remontée désactivée).
DISCORD_ERROR_WEBHOOK=

# Connexion Postgres. En dev avec docker-compose : postgres://gdt:gdt@localhost:5432/gdt
DATABASE_URL=

# Secret de signature JWT (auth). Genere : openssl rand -hex 32
JWT_SECRET=
