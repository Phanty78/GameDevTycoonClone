{
  "_comment": "Constantes des algorithmes de GDT (taille de jeu, score, review, ventes). Sources : gdt-calc (sizeConstants, formules) + wiki Fandom (Sales_Algorithm, Raw_Data 1.3.9). Beaucoup ne servent PAS au MVP (un seul jeu, pas d'équipe) mais conservées pour la suite. À calibrer.",
  "gameSizes": [
    { "id": "small",  "fanTarget": 1,       "unitPrice": 7,  "marketSizeModifier": 1.0, "salesLengthTarget": 10, "efficiencyFactor": 1.00, "scoreDivisor": 1.0, "optimalTeamSize": 1 },
    { "id": "medium", "fanTarget": 100000,  "unitPrice": 11, "marketSizeModifier": 2.0, "salesLengthTarget": 15, "efficiencyFactor": 0.75, "scoreDivisor": 1.2, "optimalTeamSize": 3 },
    { "id": "large",  "fanTarget": 250000,  "unitPrice": 14, "marketSizeModifier": 2.2, "salesLengthTarget": 20, "efficiencyFactor": 0.65, "scoreDivisor": 1.4, "optimalTeamSize": 5 },
    { "id": "aaa",    "fanTarget": 1000000, "unitPrice": 18, "marketSizeModifier": 2.5, "salesLengthTarget": 25, "efficiencyFactor": 0.50, "scoreDivisor": 1.6, "optimalTeamSize": 6 }
  ],
  "gameScore": {
    "_formula": "gameScore = m * quality * platformGenre * topicAudience * bugRatio * trendFactor",
    "m": "(design + tech) / (2 * scoreDivisor)",
    "quality": {
      "base": 1.0,
      "sliderOptimalBonus": 0.2,
      "tdRatioWithin0_25": 0.1,
      "tdRatioOffBy0_5": -0.1,
      "sameTopicGenreAsLast": -0.4,
      "sequelNewerEngine": 0.2,
      "minPointsThreshold": 30,
      "_note": "tdRatio check : t = (design * idealRatio - tech) / max(design, tech) ; |t|<=0.25 bon, |t|>0.5 mauvais"
    },
    "bugRatio": "1 - 0.8 * min(bugs*100/(tech+design), 100)/100",
    "trendFactor": { "offTrend": 1.0, "onTrend": 1.2 }
  },
  "reviewScore": {
    "_formula": "reviewScore = clamp(10 * gameScore / targetGameScore, 1, 10) * technicalExpertise/10",
    "firstThreeGamesNerf": { "scoreEq10Shown": 8.75, "scoreGte9": "score - 1.15", "scoreGt8_5": "score - 0.5" },
    "targetUpdateFactorY": { "early": 1.15, "mid_yr7_22": 1.2, "late_yr23plus": 1.1 }
  },
  "sales": {
    "_source": "Fandom Sales_Algorithm (v1.3.9)",
    "marketSizeS": "((j-h)*(g/k) + h) * f * 5_000_000   (f = 1.05 si GRID & plus fort, sinon 1)",
    "usefulMarketM": "S * marketSizeModifier",
    "U": "R^3 / (100 - 35*(R-9))   (early-game : U = (2/1000)*R^3)",
    "copiesK": "floor(M * ((2/150)*L*U + 0.008) * P)   (P = valeur plateforme/audience)",
    "finalCopiesJ": "0.8*K*(R/10) + random(0 .. 0.2*K)",
    "revenue": "J * unitPrice"
  }
}
