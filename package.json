{
  "name": "gdt-web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": ["backend", "frontend", "contracts"],
  "scripts": {
    "dev:back": "bun run --hot backend/src/index.ts",
    "dev:front": "bun --filter @gdt/frontend dev",
    "test": "bun --filter '*' test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "bun --filter='*' run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "1.*.*",
    "@types/bun": "latest",
    "typescript": "5.*.*"
  }
}
